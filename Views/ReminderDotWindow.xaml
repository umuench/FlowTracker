<Window
    x:Class="FlowTracker.Views.ReminderDotWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="22"
    Height="22"
    AllowsTransparency="True"
    Background="Transparent"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    ShowActivated="False"
    Topmost="True"
    WindowStyle="None">
    <Grid>
        <Border
            x:Name="DotBorder"
            Width="14"
            Height="14"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="#B3F59E0B"
            BorderBrush="#FFFDE68A"
            BorderThickness="1"
            CornerRadius="999"
            MouseLeftButtonUp="DotBorder_MouseLeftButtonUp" />
    </Grid>
</Window>
